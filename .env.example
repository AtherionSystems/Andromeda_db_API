# ==================
#  ORACLE CLOUD ADB
# ==================
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# ==================
#  ORACLE WALLET
# ==================
WALLET_PATH=/path/to/Wallet_andromedadb
WALLET_TRUSTSTORE_PASSWORD=your_wallet_password
WALLET_KEYSTORE_PASSWORD=your_wallet_password

# ==================
#  TELEGRAM BOT
# ==================
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_BOT_USERNAME=YourBotUsername

# ================================
#  ORACLE GENERAL CONFIGURATION
# ================================
REGION = your_oracle_region
NAMESPACE = your_namespace
OCIR_SERVER = your_ocir_server
IMAGE = your_docker_image

# ==================
#  AI CONFIGURATION
# ==================
AGENT_AI_ENABLED=true
AGENT_AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
AGENT_AI_API_KEY=<tu_gemini_api_key>
AGENT_AI_MODEL=gemini-2.0-flash
AGENT_AI_EMBEDDING_MODEL=gemini-embedding-2
