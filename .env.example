# Oracle Cloud ADB credentials
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# Oracle Wallet — local path to the unzipped wallet folder
# When running via Docker this is overridden automatically to /app/wallet
WALLET_PATH=/path/to/Wallet_andromedadb

WALLET_TRUSTSTORE_PASSWORD=your_wallet_password
WALLET_KEYSTORE_PASSWORD=your_wallet_password

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_BOT_USERNAME=YourBotUsername
